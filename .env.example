# Environment Variables for Listmizer AI
# Copy to .env and fill values

# Google Gemini (required)
GEMINI_API_KEY=your_gemini_api_key_here

# Shiprocket (for shipping tools - sign up at shiprocket.in)
VITE_SHIPROCKET_EMAIL=your@email.com
VITE_SHIPROCKET_PASSWORD=your_password

# Razorpay (for payments - get from dashboard.razorpay.com)
VITE_RAZORPAY_KEY_ID=rzp_live_xxx_or_test_xxx"

