# GEMINI_API_KEY: Server-side Gemini API key used by Vercel serverless functions.
# Keep this out of any VITE_* variables so it is never exposed to the browser.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_RAZORPAY_KEY_ID: Razorpay public key ID used by the payment page.
VITE_RAZORPAY_KEY_ID="rzp_live_SWDQzeHd5ANuxb"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
