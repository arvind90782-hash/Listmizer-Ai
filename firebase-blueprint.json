{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "displayName": { "type": "string", "description": "User's display name" },
        "email": { "type": "string", "description": "User's email address" },
        "photoURL": { "type": "string", "description": "URL to user's profile photo" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User's role in the system" },
        "createdAt": { "type": "string", "format": "date-time", "description": "ISO timestamp of account creation" }
      },
      "required": ["uid", "role"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles"
    }
  }
}
